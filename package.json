{
  "name": "backend-nest",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=testing jest",
    "test:watch": "cross-env jest --watch",
    "test:cov": "cross-env jest --coverage",
    "test:debug": "cross-env node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=testing jest --detectOpenHandles --config ./test/jest-e2e.json --runInBand",
    "test:e2e:auth": "cross-env NODE_ENV=testing jest --config ./test/jest-e2e.json --runInBand --testPathPattern=auth.e2e-spec.ts",
    "test:e2e:auth2": "cross-env NODE_ENV=testing ENV_FILE_PATH=ops jest --config ./test/jest-e2e.json --runInBand --testPathPattern=auth.e2e-spec.ts",
    "test:e2e:users": "cross-env NODE_ENV=testing jest --config ./test/jest-e2e.json --runInBand --testPathPattern=users.e2e-spec.ts",
    "test:e2e:blogs": "cross-env NODE_ENV=testing jest --config ./test/jest-e2e.json --runInBand --testPathPattern=blogs.e2e-spec.ts",
    "test:e2e:posts": "cross-env NODE_ENV=testing jest --config ./test/jest-e2e.json --runInBand --testPathPattern=posts.e2e-spec.ts",
    "test:e2e:comments": "cross-env NODE_ENV=testing jest --config ./test/jest-e2e.json --runInBand --testPathPattern=comments.e2e-spec.ts",
    "test:e2e:likes": "cross-env NODE_ENV=testing jest --config --detectOpenHandles ./test/jest-e2e.json --runInBand --testPathPattern=likes.e2e-spec.ts",
    "test:e2e:sessions": "cross-env NODE_ENV=testing jest --config ./test/jest-e2e.json --runInBand --testPathPattern=sessions.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/mongoose": "^5.11.97",
    "add": "^2.0.6",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.0.0",
    "global": "^4.4.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "^8.16.0",
    "nest-winston": "^1.10.2",
    "nodemailer": "8.0.5",
    "passport": "^0.7.0",
    "passport-http": "^0.3.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-http": "^0.3.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "types": "^0.1.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "collectCoverageFrom": [
    "**/*.(t|j)s"
  ],
  "coverageDirectory": "../coverage",
  "testEnvironment": "node"
}
